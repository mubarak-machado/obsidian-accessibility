{
  "name": "obsidian-accessibility",
  "version": "0.4.0",
  "description": "Controles acessíveis de leitura e apresentação para o Obsidian no iPad.",
  "main": "main.js",
  "type": "module",
  "private": true,
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build && npm run verify:mobile",
    "verify:mobile": "node scripts/verify-mobile-bundle.mjs",
    "verify:baseline": "node scripts/verify-release-baseline.mjs",
    "install:test": "node scripts/install-test-vault.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.1",
    "happy-dom": "^20.11.0",
    "jiti": "^2.6.1",
    "obsidian": "1.13.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "4.1.10"
  }
}
